# Database (Postgres)
DATABASE_URL="postgresql://user:Poorvigb%4025@localhost:5432/pulsecrm?schema=public"

# Server
PORT=5000

# JWT
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="15m"

# Refresh Token
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"
