# Frontend URL (used to build links in emails)
CLIENT_URL="http://localhost:5173"

# Email (SMTP) — leave blank in local dev to just log emails to the console
EMAIL_HOST=""
EMAIL_PORT=587
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="PulseCRM <no-reply@pulsecrm.dev>"

# Seed script
SEED_PASSWORD="ChangeMe123!"
